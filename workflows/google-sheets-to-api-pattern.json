{
  "name": "Google Sheets to API Pattern",
  "nodes": [
    {
      "parameters": {},
      "id": "manualTrigger",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [180, 300]
    },
    {
      "parameters": {
        "operation": "read",
        "sheetId": "your-google-sheet-id",
        "range": "Sheet1!A:D"
      },
      "id": "readSheet",
      "name": "Read Google Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [420, 300]
    },
    {
      "parameters": {
        "url": "https://api.example.com/submit",
        "responseFormat": "json"
      },
      "id": "sendToApi",
      "name": "Send Rows to API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [680, 300]
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [
        [
          {
            "node": "Read Google Sheet",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Read Google Sheet": {
      "main": [
        [
          {
            "node": "Send Rows to API",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
